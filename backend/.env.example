# 在此文件中设置 Anthropic API Key
ANTHROPIC_API_KEY=your-api-key-here

# 自定义 API Base URL（可选，用于代理或私有部署）
# ANTHROPIC_BASE_URL=https://your-proxy.example.com

# 模型名称（可选）
# MODEL_NAME=claude-sonnet-4-5-20250929

# Agent 最大工具调用轮次
# MAX_TURNS=10

# ─── PostgreSQL 配置 ───
DB_IP=127.0.0.1
DB_PORT=5432
DB_USER=root
DB_PASSWORD=your-password
DB_NAME=claude_agent

